# ============================================================
# CMS Environment Configuration
# ============================================================

# --- Server ---
# REST API listen address
BIND_ADDRESS=0.0.0.0:3000
# gRPC server listen address
GRPC_BIND_ADDRESS=0.0.0.0:50051

# --- Database ---
# Supports: sqlite:path, postgres://..., mysql://...
DATABASE_URL=sqlite:cms.db
# Connection pool settings
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=30
DB_IDLE_TIMEOUT_SECS=600

# --- Secrets (CHANGE IN PRODUCTION) ---
# JWT signing secret — used for auth token generation and verification
JWT_SECRET=change-me-in-production
# HMAC key — used for access token fast lookup hashing
HMAC_SECRET=change-me-in-production

# --- Cookie Security ---
# Set to "true" in production when serving over HTTPS
COOKIE_SECURE=false

# --- Filesystem Storage ---
# Local directory for file uploads (mutually exclusive with S3)
STORAGE_FS_PATH=./uploads

# --- S3-Compatible Storage ---
# For AWS S3, MinIO, Cloudflare R2, etc.
# All three (access key, secret key, bucket) must be set to enable S3.
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# Custom endpoint for S3-compatible services (e.g. MinIO, R2)
# S3_ENDPOINT=https://s3.amazonaws.com
# Public URL for serving assets (e.g. CDN URL)
# S3_PUBLIC_URL=https://your-cdn.example.com

# --- Upload Limits ---
# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=50

# --- Rate Limiting ---
# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100
# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECS=60

# --- TLS/HTTPS ---
# Enable TLS/HTTPS for all endpoints (REST API, gRPC, GraphQL, MCP, static SPA)
TLS_ENABLED=false
# Path to PEM-encoded certificate file
TLS_CERT_PATH=./cert.pem
# Path to PEM-encoded private key file
TLS_KEY_PATH=./key.pem
# HTTPS listen address (e.g. 0.0.0.0:443)
TLS_BIND_ADDRESS=0.0.0.0:443
# Disable HTTP listener entirely (only HTTPS+gRPC)
HTTP_DISABLED=false
# Redirect HTTP traffic to HTTPS (requires TLS_ENABLED=true)
HTTP_REDIRECT_TO_HTTPS=false
# --- MCP (Model Context Protocol) ---
# Enable/disable MCP server (true/false)
MCP_ENABLED=true
# Run MCP in stdio mode instead of HTTP (true/false)
MCP_STDIO=false
